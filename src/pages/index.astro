---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Projects from '../components/Projects.astro';
import Explainers from '../components/Explainers.astro';
import Investigations from '../components/Investigations.astro';
import AboutMe from '../components/AboutMe.astro';
import Logos from '../components/Logos.astro';
import Footer from '../components/Footer.astro';
import BaseDynamicStyles from '../components/BaseDynamicStyles.astro';

const b = import.meta.env.BASE_URL.slice(0, -1);
const previewUrl = `${Astro.url.origin}${b}/thumbnails/preview.png`;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${b}/favicon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Valeria Peredo — Mi estudio digital</title>
    <meta name="description" content="Investigación, UX/UI y visualización de datos. Convierto la complejidad en claridad." />
    <meta property="og:title" content="Valeria Peredo — Mi estudio digital" />
    <meta property="og:description" content="Investigación, UX/UI y visualización de datos. Convierto la complejidad en claridad." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={previewUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={previewUrl} />
    <BaseDynamicStyles />
  </head>
  <body class="bg-blue-50 font-body">
    <Header />
    <main>
      <Hero />
      <Services />
      <Projects />
      <Explainers />
      <Investigations />
      <AboutMe />
      <Logos />
    </main>
    <Footer />
  </body>
</html>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in-view');
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
  );
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
</script>
