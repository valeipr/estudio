---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseDynamicStyles from '../components/BaseDynamicStyles.astro';

const b = import.meta.env.BASE_URL.replace(/\/$/, "");
const previewUrl = `${Astro.url.origin}${b}/thumbnails/preview.png`;

const ilustraciones = [
  { src: `${b}/jardin-ilustraciones/ciberias.jpg`,              alt: "Ilustración de ciberias"              },
  { src: `${b}/jardin-ilustraciones/ciberias2.jpg`,             alt: "Ilustración de ciberias 2"            },
  { src: `${b}/jardin-ilustraciones/mujeres.jpg`,               alt: "Ilustración de mujeres"               },
  { src: `${b}/jardin-ilustraciones/bmo.jpg`,                   alt: "Ilustración de BMO (Adventure Time)"  },
  { src: `${b}/jardin-ilustraciones/totoro.jpg`,                alt: "Ilustración de Totoro"                },
  { src: `${b}/jardin-ilustraciones/fanart.jpg`,                alt: "Fanart"                               },
  { src: `${b}/jardin-ilustraciones/robot.jpg`,                 alt: "Ilustración de robot"                 },
  { src: `${b}/jardin-ilustraciones/rootmars.jpg`,              alt: "Ilustración de Root Mars"             },
  { src: `${b}/jardin-ilustraciones/compu.png`,                 alt: "Ilustración de computadora"           },
  { src: `${b}/jardin-ilustraciones/LuisArce.jpg`,              alt: "Ilustración de Luis Arce"             },
  { src: `${b}/jardin-ilustraciones/portadas-digsocietal.png`,  alt: "Portadas Digsocietal"                 },
  { src: `${b}/jardin-ilustraciones/yoshiki.jpg`,               alt: "Ilustración de Yoshiki"               },
  { src: `${b}/jardin-ilustraciones/yupay.jpg`,                 alt: "Ilustración de Yupay"                 },
  { src: `${b}/jardin-ilustraciones/mentorbot.png`,             alt: "Ilustración de Mentorbot"              },
  { src: `${b}/jardin-ilustraciones/mockups-yupay.png`,                 alt: "Pantallas de Yupay"              },
  { src: `${b}/jardin-ilustraciones/bicidatos.png`,                 alt: "Pantallas de Bicidatos"                 },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${b}/favicon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Jardín digital — Valeria Peredo</title>
    <meta name="description" content="Una colección de ilustraciones personales: fanart, bocetos y experimentos visuales de Valeria Peredo." />
    <meta property="og:title" content="Jardín digital — Valeria Peredo" />
    <meta property="og:description" content="Una colección de ilustraciones personales: fanart, bocetos y experimentos visuales." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={previewUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={previewUrl} />
    <BaseDynamicStyles />
  </head>
  <body class="bg-blue-50 font-body">
    <div class="fixed inset-0 dot-pattern pointer-events-none z-0" aria-hidden="true"></div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <Header />

      <main class="flex-1 py-10 md:py-14">
        <div class="max-w-[1000px] mx-auto px-4 md:px-9">

          <!-- Encabezado -->
          <a href={`${b}/`}
             class="inline-flex items-center gap-2 font-body text-type-16 text-grey-500 hover:text-green-600 transition-colors no-underline mb-6 group">
            <span class="inline-block transition-transform group-hover:-translate-x-1">←</span>
            <span>Volver al inicio</span>
          </a>

          <div class="mb-3">
            <span class="inline-block bg-green-100 text-green-800 font-body font-semibold text-type-12 uppercase tracking-[0.1em] px-3 py-1 rounded-full">
              Ilustración
            </span>
          </div>

          <h1 class="font-heading text-type-48 md:text-type-64 text-teal-900 leading-tight mb-4" data-animate>
            Jardín de ilustraciones
          </h1>

          <p class="font-body text-type-21 text-grey-500 leading-[1.5] mb-10 max-w-[640px]" data-animate style="--anim-delay: 80ms">
            Dibujos personales: fanart, bocetos, afiches, portadas de libros y experimentos visuales que he ido haciendo a lo largo de los años. Haz clic en cualquier imagen para verla ampliada.
          </p>

          <!-- Galería -->
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5" id="gallery">
            {ilustraciones.map((img, i) => (
              <button
                class="gallery-item group block w-full rounded-[5px] overflow-hidden border border-grey-50 aspect-square focus:outline-none focus-visible:ring-2 focus-visible:ring-green-600"
                data-src={img.src}
                data-alt={img.alt}
                data-index={i}
                data-animate
                style={`--anim-delay: ${i * 40}ms`}
                aria-label={`Ver: ${img.alt}`}
              >
                <img
                  src={img.src}
                  alt={img.alt}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.04]"
                />
              </button>
            ))}
          </div>

        </div>
      </main>

      <Footer />
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Vista ampliada" aria-hidden="true">
      <button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">✕</button>

      <button
        id="lightbox-prev"
        aria-label="Anterior"
        class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center text-teal-900 text-lg transition-colors hover:bg-green-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-green-600 z-10"
      >←</button>

      <img id="lightbox-img" src="" alt="" class="lightbox-img" />

      <button
        id="lightbox-next"
        aria-label="Siguiente"
        class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full flex items-center justify-center text-teal-900 text-lg transition-colors hover:bg-green-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-green-600 z-10"
      >→</button>

      <p id="lightbox-caption" class="absolute bottom-5 left-1/2 -translate-x-1/2 font-body text-type-12 text-white/70 whitespace-nowrap"></p>
    </div>

    <script>
      // Intersection observer para animaciones
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
      );
      document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

      // Lightbox
      const lightbox     = document.getElementById('lightbox') as HTMLElement;
      const lightboxImg  = document.getElementById('lightbox-img') as HTMLImageElement;
      const caption      = document.getElementById('lightbox-caption') as HTMLElement;
      const items        = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-item'));
      let current        = 0;

      function openLightbox(index: number) {
        current = index;
        const item = items[index];
        const src  = item.dataset.src ?? '';
        const alt  = item.dataset.alt ?? '';
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        caption.textContent = alt;
        lightbox.classList.add('is-open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.classList.remove('is-open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        setTimeout(() => { lightboxImg.src = ''; }, 200);
      }

      function navigate(dir: number) {
        openLightbox((current + dir + items.length) % items.length);
      }

      items.forEach((btn, i) => btn.addEventListener('click', () => openLightbox(i)));

      document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
      document.getElementById('lightbox-prev')?.addEventListener('click',  () => navigate(-1));
      document.getElementById('lightbox-next')?.addEventListener('click',  () => navigate(1));

      lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });

      document.addEventListener('keydown', e => {
        if (!lightbox.classList.contains('is-open')) return;
        if (e.key === 'Escape')     closeLightbox();
        if (e.key === 'ArrowLeft')  navigate(-1);
        if (e.key === 'ArrowRight') navigate(1);
      });
    </script>
  </body>
</html>
