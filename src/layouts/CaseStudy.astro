---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  cover: string;
  tags: string[];
  readTime?: number;
  overview?: {
    cliente?: string;
    herramientas?: string;
    año?: string;
    rol?: string;
  };
}

const { title, description, category, date, cover, tags, readTime = 5, overview } = Astro.props;

const dateFormatted = new Date(date + 'T12:00:00').toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
});
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content="Astro" />
    <title>{title} — Valeria Peredo</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-blue-50 font-body">
    <!-- Dot pattern global fijo (mismo que en la home) -->
    <div class="fixed inset-0 dot-pattern pointer-events-none z-0" aria-hidden="true"></div>

    <div class="relative z-10">
    <Header />

    <!-- Hero: directo sobre el fondo punteado, sin card -->
    <section class="py-8 md:py-12">
      <div class="max-w-[1000px] mx-auto px-4 md:px-9">

        <!-- Volver -->
        <a href="/#proyectos"
           class="inline-flex items-center gap-2 font-body text-type-16 text-grey-500 hover:text-green-600 transition-colors no-underline mb-6 group">
          <span class="inline-block transition-transform group-hover:-translate-x-1">←</span>
          <span>Volver a proyectos</span>
        </a>

        <!-- Categoría -->
        <div class="mb-4">
          <span class="inline-block bg-green-100 text-green-800 font-body font-semibold text-type-12 uppercase tracking-[0.1em] px-3 py-1 rounded-full">
            {category}
          </span>
        </div>

        <!-- Título -->
        <h1 class="font-heading text-type-48 md:text-type-64 text-teal-900 leading-[1.0] mb-5">
          {title}
        </h1>

        <!-- Descripción -->
        <p class="font-body text-type-21 text-grey-500 leading-[1.5] mb-6 max-w-[680px]">
          {description}
        </p>

        <!-- Meta: fecha + lectura -->
        <div class="flex items-center gap-3 font-body text-type-16 text-grey-500">
          <span>{dateFormatted}</span>
          <span class="w-1 h-1 rounded-full bg-grey-100" aria-hidden="true"></span>
          <span>{readTime} min de lectura</span>
        </div>

      </div>
    </section>

    <!-- Imagen de portada -->
    <div class="max-w-[1000px] mx-auto px-4 md:px-9 mb-8">
      <div class="rounded-[5px] border border-grey-50 overflow-hidden h-[240px] sm:h-[360px] md:h-[460px]">
        <img
          src={cover}
          alt={`Portada del proyecto ${title}`}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Tags: directo sobre el fondo punteado, sin card -->
    <div class="max-w-[1000px] mx-auto px-4 md:px-9 flex flex-wrap gap-2 mb-6">
      {tags.map(tag => (
        <span class="bg-cards-bg border border-grey-100 text-grey-500 font-body text-type-12 px-3 py-1 rounded-full">
          {tag}
        </span>
      ))}
    </div>

    <!-- Overview: directo sobre el fondo, sin card -->
    {overview && (
      <div class="max-w-[1000px] mx-auto px-4 md:px-9 mb-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10">
          {overview.cliente && (
            <div class="flex flex-col gap-1">
              <span class="font-body font-bold text-type-12 text-grey-800 uppercase tracking-[0.08em]">Cliente</span>
              <span class="font-body text-type-16 text-grey-500 leading-[1.3]">{overview.cliente}</span>
            </div>
          )}
          {overview.rol && (
            <div class="flex flex-col gap-1">
              <span class="font-body font-bold text-type-12 text-grey-800 uppercase tracking-[0.08em]">Rol</span>
              <span class="font-body text-type-16 text-grey-500 leading-[1.3]">{overview.rol}</span>
            </div>
          )}
          {overview.herramientas && (
            <div class="flex flex-col gap-1">
              <span class="font-body font-bold text-type-12 text-grey-800 uppercase tracking-[0.08em]">Herramientas</span>
              <span class="font-body text-type-16 text-grey-500 leading-[1.3]">{overview.herramientas}</span>
            </div>
          )}
          {overview.año && (
            <div class="flex flex-col gap-1">
              <span class="font-body font-bold text-type-12 text-grey-800 uppercase tracking-[0.08em]">Año</span>
              <span class="font-body text-type-16 text-grey-500 leading-[1.3]">{overview.año}</span>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Artículo: card crema solo para el cuerpo del texto -->
    <main class="max-w-[1000px] mx-auto px-4 md:px-9 pb-16">
      <div class="bg-cards-bg border border-grey-50 rounded-[5px] px-6 md:px-10 py-8 md:py-10">

        <article class="case-prose">
          <slot />
        </article>

        <!-- Divisor + CTA final -->
        <div class="mt-14 pt-8 border-t border-grey-50 flex flex-col sm:flex-row items-start sm:items-center gap-4 justify-between">
          <a href="/#proyectos"
             class="inline-flex items-center gap-2 bg-green-600 text-white font-heading text-type-20 px-5 py-2.5 rounded-[5px] hover:bg-green-300 transition-colors no-underline leading-none">
            ← Ver más proyectos
          </a>
          <a href="/#contacto"
             class="inline-flex items-center gap-2 border border-green-600 text-green-600 font-heading text-type-20 px-5 py-2.5 rounded-[5px] hover:bg-green-100 transition-colors no-underline leading-none">
            ¿Trabajamos juntos?
          </a>
        </div>

      </div>
    </main>

    <Footer />
    </div>

    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -48px 0px' }
      );
      document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
