---
const b = import.meta.env.BASE_URL.slice(0, -1); // '/estudio' in prod, '' in dev
---
<script is:inline define:vars={{ b }}>
(function () {
  var s = document.createElement('style');
  s.textContent =
    '.dot-pattern{background-image:url(' + b + '/background.png)}' +
    'html{cursor:url(' + b + '/icons/default-alt-dark.svg) 12 10,auto}' +
    'a,button,[role="button"],.cursor-pointer{cursor:url(' + b + '/icons/pointer.svg) 18 6,pointer}' +
    'input,textarea,select{cursor:text}' +
    '.case-prose img{cursor:url(' + b + '/icons/pointer.svg) 18 6,pointer}';
  document.head.appendChild(s);
}());
</script>
