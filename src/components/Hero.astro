---
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<section class="relative bg-blue-50 overflow-hidden flex items-start md:items-center justify-center py-4 md:py-8
                min-h-[calc(100dvh-65px)]">

  <!-- Patrón de fondo -->
  <div class="absolute inset-0 dot-pattern pointer-events-none" aria-hidden="true"></div>

  <!-- Wrapper relativo: ancla las estrellitas a las esquinas del card -->
  <div class="relative z-10 w-[calc(100%-2rem)] max-w-[1200px] mx-auto my-6 lg:my-10">

    <!-- Estrellas — solo desktop grande -->
    <img src={`${b}/icons/star-icon.png`} alt="" aria-hidden="true"
      class="hidden lg:block absolute -top-9 -left-9 w-[66px] h-[65px] object-contain pointer-events-none z-20" />
    <img src={`${b}/icons/star-icon.png`} alt="" aria-hidden="true"
      class="hidden lg:block absolute -bottom-9 -right-9 w-[66px] h-[65px] object-contain pointer-events-none z-20" />
    <img src={`${b}/icons/star-icon.png`} alt="" aria-hidden="true"
      class="hidden lg:block absolute -bottom-3 -right-[4.5rem] w-[54px] h-[53px] object-contain pointer-events-none opacity-80 z-20" />

    <!-- Tarjeta principal: columna en móvil, fila desde md -->
    <div data-animate="fade-in"
         class="animate-float bg-cards-bg border border-grey-50 rounded-2xl shadow-[0_4px_2px_rgba(0,0,0,0.15)]
                flex flex-col md:flex-row gap-6 md:gap-8 lg:gap-10 items-center
                px-6 md:px-8 lg:px-14 py-10 lg:py-14">

      <!-- Ilustración — solo en móvil (< md) -->
      <div class="w-full md:hidden rounded-xl overflow-hidden">
        <img
          src={`${b}/fotos e ilustraciones/1-hero-illustration.jpg`}
          alt="Ilustración de Valeria trabajando en su estudio digital"
          class="w-full max-h-[280px] object-cover object-top rounded-xl"
        />
      </div>

      <!-- Columna de texto -->
      <div class="flex-1 flex flex-col gap-6 lg:gap-8 w-full min-w-0 items-center md:items-start text-center md:text-left">

        <div class="flex flex-col gap-2">
          <h1 class="font-heading text-teal-900 leading-[0.85]
                     text-[2.25rem] md:text-[2.75rem] lg:text-type-85">
            Valeria Peredo Rodríguez
          </h1>

          <div class="flex flex-col gap-4 lg:gap-5">
            <p class="font-heading text-type-20 md:text-type-27 text-grey-800 leading-none">
              Investigación | UX/UI | Visualización de datos
            </p>

            <div class="flex flex-col gap-2 font-body text-type-16 leading-[1.4]">
              <p class="font-bold text-green-800">
                🌱 Mi trabajo es convertir la complejidad en claridad.
              </p>
              <p class="text-grey-500 max-w-[448px] mx-auto md:mx-0">
                Ayudo a organizaciones a traducir problemas complejos en experiencias, productos
                digitales, visualizaciones, mapas y narrativas que las personas puedan entender y usar.
              </p>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3 justify-center md:justify-start">
          <a href="#contacto"
            class="bg-green-600 text-white font-heading text-type-20 md:text-type-27 leading-none px-4 py-3 rounded-[5px] hover:bg-green-300 transition-colors no-underline">
            CONTACTAME
          </a>
          <a href="https://docs.google.com/document/d/1L6QlDHQ9B0H4KmryTW-euBr_wyUTpQZKNoB1nkknjho/edit?usp=sharing" target="_blank" rel="noopener"
            class="border border-green-600 text-green-600 font-heading text-type-20 md:text-type-27 leading-none px-4 py-3 rounded-[5px] hover:bg-green-100 transition-colors no-underline">
            Descargar CV
          </a>
        </div>

      </div>

      <!-- Ilustración — tablet (md) y desktop (lg) -->
      <div class="hidden md:block shrink-0 rounded-2xl overflow-hidden
                  w-[260px] h-[320px] md:w-[300px] md:h-[360px] lg:w-[524px] lg:h-[440px]">
        <img
          src={`${b}/fotos e ilustraciones/1-hero-illustration.jpg`}
          alt="Ilustración de Valeria trabajando en su estudio digital"
          class="w-full h-full object-cover"
        />
      </div>

    </div>
  </div>
</section>
