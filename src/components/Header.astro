---
<header class="sticky top-0 z-50 bg-blue-50 border-b border-grey-100">
  <div class="flex items-center justify-between h-[65px] max-w-[1000px] mx-auto px-4 md:px-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline shrink-0">
      <img src="/icons/computer.png" alt="" class="w-7 h-7 object-contain" aria-hidden="true" />
      <span class="font-heading text-type-27 text-teal-900 leading-none">
        Mi estudio digital
      </span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:block">
      <ul class="flex items-center gap-6 lg:gap-10 list-none font-body text-type-16 text-grey-500">
        <li><a href="#servicios" class="hover:text-green-600 transition-colors">¿Qué hago?</a></li>
        <li><a href="#proyectos" class="hover:text-green-600 transition-colors">Proyectos</a></li>
        <li><a href="#sobre-mi" class="hover:text-green-600 transition-colors">Sobre mí</a></li>
        <li>
          <a href="#contacto" class="bg-green-600 text-white font-heading text-type-20 px-3 py-1.5 rounded-[5px] hover:bg-green-300 transition-colors no-underline leading-none">
            Contáctame
          </a>
        </li>
      </ul>
    </nav>

    <!-- Botón contacto móvil -->
    <a href="#contacto" class="md:hidden bg-green-600 text-white font-heading text-type-20 px-3 py-1.5 rounded-[5px] no-underline leading-none">
      Contacto
    </a>

  </div>
</header>
