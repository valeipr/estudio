---
const b = import.meta.env.BASE_URL.replace(/\/$/, "");
const projects = [
  {
    slug: 'tarpuy',
    image: `${b}/thumbnails/1-tarpuy.png`,
    title: 'Tarpuy, una app para productores cochabambinos',
    description: 'Diseñé la app móvil para compradores y la web app para productores, validando la interfaz en talleres participativos con las propias organizaciones cochabambinas.',
  },
  {
    slug: 'olimpiadas-cientificas',
    image: `${b}/thumbnails/2-olimpiadas cientificas.png`,
    title: 'Desigualdades educativas en las Olimpiadas Científicas',
    description: 'Construí una base de datos propia y descubrí que el 60% de las medallas van a colegios privados. La investigación abrió una conversación pública nacional.',
  },
  {
    slug: 'bolivia-tierra-envenenada',
    image: `${b}/thumbnails/3-bolivia el pais de la tierra envenenada.png`,
    title: 'Bolivia, el país de la tierra envenenada',
    description: 'Creé la identidad visual y la ilustración de portada de una investigación sobre contaminación minera en Bolivia. Ganó el Premio Nacional de Periodismo Digital e Investigación 2024.',
  },
  {
    slug: 'mi-huella',
    image: `${b}/thumbnails/6-mi huella.png`,
    title: 'Diseño UX/UI de la app Mi Huella',
    description: 'Rediseñé la app de huella de carbono para jóvenes, transformando una interfaz tipo formulario en una experiencia con gamificación y un personaje ilustrado propio.',
  },
  {
    slug: 'mapas-3d',
    image: `${b}/thumbnails/5-mapas-3d.png`,
    title: 'Densidad poblacional en 3D',
    description: 'Usé Rayshader en R para crear mapas 3D de densidad poblacional en los 9 departamentos de Bolivia, donde el reto fue estético —paleta, ángulo, iluminación— más que técnico.',
  },
];
---

<section id="proyectos" class="relative bg-blue-50 overflow-hidden py-6 md:py-10">
  <div class="absolute inset-0 dot-pattern pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-[1000px] mx-auto px-4 md:px-9">

    <!-- Encabezado -->
    <div data-animate class="flex items-center justify-center gap-4 py-8 md:py-10">
      <img src={`${b}/icons/pin.png`} alt="" aria-hidden="true"
        class="w-8 h-8 md:w-12 md:h-12 object-contain shrink-0" />
      <h2 class="font-heading text-type-27 md:text-type-48 text-grey-800 leading-[0.8]">
        Mis proyectos destacados
      </h2>
    </div>

    <!-- Grid: 1 col → 2 col, cada tarjeta con stagger par/impar -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-8">
      {projects.map((project, i) => (
        <a href={`${b}/proyectos/${project.slug}`}
           data-animate style={`--anim-delay:${(i % 2) * 120}ms`}
           class="bg-cards-bg border border-grey-50 rounded-[5px] flex flex-col items-end justify-between gap-4 md:gap-6 px-5 md:px-7 py-6 md:py-8
                  hover:-translate-y-2 hover:shadow-[0_12px_28px_rgba(0,0,0,0.1)] hover:border-green-300 cursor-pointer no-underline
                  [&:last-child]:md:col-span-2 [&:last-child]:md:w-[calc((100%-1.5rem)/2)] [&:last-child]:md:mx-auto">
          <div class="border border-grey-50 rounded-[5px] h-[200px] sm:h-[240px] md:h-[282px] overflow-hidden w-full shrink-0">
            <img src={project.image} alt={project.title} class="w-full h-full object-cover" />
          </div>
          <div class="w-full flex flex-col">
            <h3 class="font-heading text-type-27 md:text-type-36 text-grey-800 leading-[1.2]">
              {project.title}
            </h3>
            <p class="font-body text-type-16 text-grey-500 leading-[1.4]">{project.description}</p>
          </div>
          <span class="shrink-0 bg-green-600 text-white font-heading text-type-20 leading-[1.5] px-4 py-2 rounded-[5px] hover:bg-green-300 transition-colors">
            CONOCE EL PROYECTO
          </span>
        </a>
      ))}
    </div>

  </div>
</section>
