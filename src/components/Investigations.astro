---
const papers = [
  {
    title: 'Organización, discurso y actividad digital. Una aproximación al movimiento Antivacunas en grupos de WhatsApp',
    year: '2022',
    venue: 'Revista Punto Cero',
    description: 'Este artículo es una etnografía digital de los grupos antivacunas que se manifestaron en contra de la vacunación obligatoria promovida por el gobierno para luchar contra el COVID-19, en enero de 2022.',
    href: '#',
  },
  {
    title: 'Desarrollo de software, educación STEM y hubs metropolitanos: El caso de Cochabamba',
    year: '2025',
    venue: 'La Bolivia del Futuro — Innovación y diversificación post-extractivista',
    description: 'Este artículo analiza el potencial de la industria de software como una alternativa al modelo económico extractivista de Bolivia, centrándonos en el caso de Cochabamba. Coescrito con Alex Ojeda.',
    href: '#',
  },
  {
    title: 'Una exploración bibliométrica y digital de los Estudios Urbanos en Bolivia',
    year: '2022',
    venue: 'Memoria del Congreso Boliviano de Urbanismo',
    description: 'Armé y analicé una base de datos de más de 500 publicaciones sobre ciudades bolivianas para ver el desarrollo de los Estudios Urbanos en el país.',
    href: '#',
  },
];
---

<section id="investigaciones" class="relative bg-blue-50 overflow-hidden py-6 md:py-10">
  <div class="absolute inset-0 dot-pattern pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-[1000px] mx-auto px-4 md:px-9">

    <!-- Encabezado -->
    <div data-animate class="flex items-center justify-center gap-4 py-8 md:py-10">
      <img src="/icons/investigacion-file.png" alt="" aria-hidden="true"
        class="w-8 h-8 md:w-12 md:h-12 object-contain shrink-0" />
      <h2 class="font-heading text-type-36 md:text-type-48 text-grey-800 leading-[0.8]">
        Investigación académica
      </h2>
    </div>

    <!-- Lista de papers -->
    <div class="flex flex-col gap-4 pb-8 md:pb-10">
      {papers.map((paper, i) => (
        <div data-animate style={`--anim-delay:${i * 100}ms`}
             class="bg-cards-bg border border-grey-50 rounded-[5px] px-6 md:px-8 py-6 md:py-7
                    flex flex-col gap-4
                    hover:border-green-300 hover:shadow-[0_8px_24px_rgba(0,0,0,0.07)] transition-all duration-200">

          <!-- Año + publicación -->
          <p class="font-body text-type-12 text-grey-500 leading-none">
            {paper.year} · <span class="italic">{paper.venue}</span>
          </p>

          <!-- Título -->
          <h3 class="font-body font-bold text-type-16 md:text-type-21 text-grey-800 leading-[1.3]">
            {paper.title}
          </h3>

          <!-- Descripción -->
          <p class="font-body text-type-16 text-grey-500 leading-[1.6] max-w-[720px]">
            {paper.description}
          </p>

          <!-- Botón -->
          <div class="flex justify-end">
            <a href={paper.href}
               class="border border-green-600 text-green-600 font-body text-type-16 font-semibold leading-none
                      px-4 py-2 rounded-[5px] hover:bg-green-100 transition-colors no-underline shrink-0">
              Lee el trabajo
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
